<UserControl x:Class="Copier.Views.SelectFolder"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Copier.Views"
             xmlns:converters="clr-namespace:Copier.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <converters:FolderButtonConverter x:Key="FolderButtonConverter"/>
        <ControlTemplate x:Key="EmptyListTemplate" TargetType="ItemsControl">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="No files found" FontSize="16" FontWeight="Bold" Foreground="Gray"/>
            </StackPanel>
        </ControlTemplate>
    </UserControl.Resources>

    <Grid Background="{StaticResource DarkAlt}">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="25" Padding="10" VerticalAlignment="Center"/>
        <Button Grid.Row="1" Command="{Binding SelectFolderCommand}" Padding="5, 5, 0, 5" Content="{Binding CurrentPath, Converter={StaticResource FolderButtonConverter}}" 
                 HorizontalContentAlignment="Left" FontWeight="Bold" BorderThickness="0" Background="{StaticResource DarkMain}" Foreground="{StaticResource MainText}">
        </Button>

        <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Files}">
                <ItemsControl.Style>
                    <Style TargetType="ItemsControl">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Files.Count}" Value="0">
                                <Setter Property="Template" Value="{StaticResource EmptyListTemplate}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ItemsControl.Style>
                <ItemsControl.ItemContainerStyle>
                    <Style>
                        <Setter Property="FrameworkElement.Margin" Value="5, 1, 0, 1"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>