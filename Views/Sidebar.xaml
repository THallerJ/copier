<UserControl x:Class="Copier.Views.Sidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Copier.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Saved Jobs" FontSize="15" VerticalAlignment="Center" Margin="5 0 0 0" FontWeight="SemiBold"/>
        <ListBox Grid.Row="1" ItemsSource="{Binding Jobs}" DisplayMemberPath="Id" Margin="0 0 0 0"/>
    </Grid>
</UserControl>
